<?xml version="1.0" encoding="UTF-8"?>
<interface>
	<object class="GtkBox" id="body">
		<property name="orientation">vertical</property>
		<property name="halign">start</property>
		<child>
			<object class="GtkLabel">
				<property name="label">Hello world!</property>
			</object>
		</child>
	</object>
</interface>

